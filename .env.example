# .env.example — copy to .env and fill in real values
# .env is gitignored and must never be committed.

# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key — used when judge_provider or generator_provider is "anthropic".
# Not needed when both providers are set to "openai".
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional provider keys ───────────────────────────────────────────────────
# OpenAI API key — needed when judge_provider or generator_provider is "openai".
# Judge and generator can use different providers, e.g. GPT-4o judge + Haiku generator.
# OPENAI_API_KEY=sk-...

# ── Optional target auth ─────────────────────────────────────────────────────
# Bearer token sent as "Authorization: Bearer <value>" to the target RAG API.
# TARGET_TOKEN=

# API key sent as "X-Api-Key: <value>" to the target RAG API.
# TARGET_API_KEY=
